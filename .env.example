# Pack — environment variables
# Copy to .env.local for development or set before `npm run build` for production.

# ---------------------------------------------------------------------------
# App URL (password reset redirects, auth callbacks)
# ---------------------------------------------------------------------------
VITE_APP_URL=https://pack.okamidesigns.com

# ---------------------------------------------------------------------------
# Supabase (cloud accounts + sync) — client-safe keys only
# Get these from: Supabase Project → Settings → API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Mapbox (maps + place search) — public token only (pk.*)
# Get from: Mapbox Account → Access tokens
# ---------------------------------------------------------------------------
VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# NEVER put a secret Mapbox token (sk.*) in the client build.
# Service role is for server-side admin scripts / Edge Functions only.

# ---------------------------------------------------------------------------
# Linux deployment paths (install.sh — server only, not Vite)
# ---------------------------------------------------------------------------
PACK_DOMAIN=pack.okamidesigns.com
PACK_WEB_ROOT=/var/www/pack
PACK_APP_DIR=/opt/pack
PACK_DATA_DIR=/opt/pack/data
PACK_UPLOADS_DIR=/opt/pack/uploads
PACK_BACKUPS_DIR=/opt/pack/backups
PACK_GIT_BRANCH=main
PACK_REPO_URL=https://github.com/Jallison154/PACK.git

# Optional: private GitHub clone token (install script only)
# PACK_GITHUB_TOKEN=ghp_your_token_here

# ---------------------------------------------------------------------------
# Optional self-hosted PostgreSQL (advanced — Supabase is recommended)
# Used only if you add a custom API layer later.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/pack
# AUTH_SECRET=generate-a-long-random-string
